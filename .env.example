# ==== 启用的平台（逗号分隔） ====
# 可选：wecom | lark | console
PLATFORMS=wecom

# ==== 企业微信 ====
# 单机器人（兼容旧配置），注册名 = `wecom`
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# 多机器人（优先生效，设置后 WECOM_BOT_ID/SECRET 会被忽略）
# id 只允许 [a-zA-Z0-9_-]，注册名 = `wecom:<id>`，不同 bot 之间会话、提醒、agent 记忆全部独立
# WECOM_BOTS=[{"id":"hr","botId":"xxx","secret":"yyy"},{"id":"ops","botId":"aaa","secret":"bbb"}]

# ==== 飞书（stub，未实现） ====
# LARK_APP_ID=
# LARK_APP_SECRET=
# LARK_ENCRYPT_KEY=
# LARK_VERIFICATION_TOKEN=

# ==== Agent 选择 ====
# 可选：claude | gemini | codex
AGENT=claude
# 可选：覆盖默认 CLI 路径（默认按 AGENT 名字从 PATH 找）
# AGENT_CLI_PATH=/usr/local/bin/claude
AGENT_TIMEOUT_MS=300000

# gemini 专用模型
GEMINI_MODEL=gemini-2.5-flash

# ==== HTTP 主动推送入口 ====
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
HTTP_TOKEN=change-me-to-a-random-string

# ==== 日志 / 行为 ====
LOG_LEVEL=info
GROUP_ONLY_AT_ME=true
STREAM_FLUSH_MS=300

# ==== 提醒存储 ====
REMINDER_DB_PATH=data/reminders.db
