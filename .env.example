# ==== 启用的平台（逗号分隔） ====
# 可选：wecom | lark | console
PLATFORMS=wecom

# ==== 企业微信 ====
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# ==== 飞书（stub，未实现） ====
# LARK_APP_ID=
# LARK_APP_SECRET=
# LARK_ENCRYPT_KEY=
# LARK_VERIFICATION_TOKEN=

# ==== Agent 选择 ====
# 可选：claude | gemini | codex
AGENT=claude
# 可选：覆盖默认 CLI 路径（默认按 AGENT 名字从 PATH 找）
# AGENT_CLI_PATH=/usr/local/bin/claude
AGENT_TIMEOUT_MS=300000

# gemini 专用模型
GEMINI_MODEL=gemini-2.5-flash

# ==== HTTP 主动推送入口 ====
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
HTTP_TOKEN=change-me-to-a-random-string

# ==== 日志 / 行为 ====
LOG_LEVEL=info
GROUP_ONLY_AT_ME=true
STREAM_FLUSH_MS=300

# ==== 提醒存储 ====
REMINDER_DB_PATH=data/reminders.db
